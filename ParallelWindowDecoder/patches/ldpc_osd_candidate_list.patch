         return out
 
+    def decode_list(self, syndrome: np.ndarray, top_k: int = 4, force_osd: bool = False) -> np.ndarray:
+        """
+        Decodes the input syndrome and returns up to ``top_k`` OSD candidates.
+
+        If BP converges and ``force_osd`` is false, the returned list contains only
+        the BP decoding. Otherwise, OSD is run once and the C++ OSD search keeps
+        the best ``top_k`` candidate decodings encountered internally.
+        """
+
+        cdef int i
+        cdef int j
+        cdef int row_count
+
+        if top_k < 1:
+            raise ValueError("top_k must be at least 1.")
+
+        if not len(syndrome) == self.m:
+            raise ValueError(f"The syndrome must have length {self.m}. Not {len(syndrome)}.")
+
+        zero_syndrome = True
+
+        for i in range(self.m):
+            self._syndrome[i] = syndrome[i]
+            if self._syndrome[i]:
+                zero_syndrome = False
+        if zero_syndrome:
+            self.bpd.converge = True
+            return np.zeros((1, self.n), dtype=syndrome.dtype)
+
+        self.bpd.decode(self._syndrome)
+
+        if self.bpd.converge and not force_osd:
+            out = np.zeros((1, self.n), dtype=syndrome.dtype)
+            for i in range(self.n):
+                out[0, i] = self.bpd.decoding[i]
+            return out
+
+        self.osdD.set_osd_candidate_list_size(top_k)
+        self.osdD.decode(self._syndrome, self.bpd.log_prob_ratios)
+        self.osdD.set_osd_candidate_list_size(0)
+
+        row_count = self.osdD.osd_candidate_decodings.size()
+        if row_count == 0:
+            row_count = 1
+            out = np.zeros((row_count, self.n), dtype=syndrome.dtype)
+            for i in range(self.n):
+                out[0, i] = self.osdD.osdw_decoding[i]
+            return out
+
+        out = np.zeros((row_count, self.n), dtype=syndrome.dtype)
+        for i in range(row_count):
+            for j in range(self.n):
+                out[i, j] = self.osdD.osd_candidate_decodings[i][j]
+
+        return out
+
+    @property
+    def osd_candidate_weights(self) -> List[float]:
+        """Returns the weights from the most recent ``decode_list`` OSD run."""
+        cdef int i
+        return [self.osdD.osd_candidate_weights[i] for i in range(self.osdD.osd_candidate_weights.size())]
+
 
 
     @property
